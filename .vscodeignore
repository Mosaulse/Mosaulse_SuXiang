# Ignore files for VS Code extension packaging
# See: https://code.visualstudio.com/api/working-with-extensions/publishing-extension

# Docs and previews (not needed in .vsix)
docs/

# Workspace config
.workbuddy/
.trae/
.reasonix/
scripts

# Development files
*.log
*.tmp

# OS files
.DS_Store
Thumbs.db

# Git files (optional, usually auto-ignored)
.git/
.gitignore

themes/
!themes/base.json
!themes/suxiang-dark-青碧.json
!themes/suxiang-light-青碧.json