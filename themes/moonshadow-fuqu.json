    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "comment.line",
                "comment.block",
                "comment.line.double-slash",
                "comment.line.number-sign",
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#6A7A8A",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Comment — documentation",
            "scope": [
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#7A8A9A",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Keyword — Control flow, declarations",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.expression",
                "keyword.other",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#D47A7A"
            }
        },
        {
            "name": "Keyword — import, include, package",
            "scope": [
                "keyword.control.import",
                "keyword.control.include",
                "keyword.control.package",
                "keyword.control.namespace"
            ],
            "settings": {
                "foreground": "#D47A7A"
            }
        },
        {
            "name": "Operator",
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment",
                "keyword.operator.comparison",
                "keyword.operator.arithmetic",
                "keyword.operator.logical"
            ],
            "settings": {
                "foreground": "#D47A7A"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "string.quoted",
                "string.quoted.single",
                "string.quoted.double",
                "string.quoted.triple",
                "string.quoted.other",
                "string.unquoted"
            ],
            "settings": {
                "foreground": "#5CB87A"
            }
        },
        {
            "name": "String — template & interpolation",
            "scope": [
                "string.template",
                "string.template variable",
                "string.interpolation",
                "string.interpolated"
            ],
            "settings": {
                "foreground": "#5CB87A"
            }
        },
        {
            "name": "String — escape sequences",
