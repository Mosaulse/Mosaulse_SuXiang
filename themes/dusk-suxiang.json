    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "comment.line",
                "comment.block",
                "comment.line.double-slash",
                "comment.line.number-sign",
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#9a8878",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Comment — documentation",
            "scope": [
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#9a8878",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Keyword — Control flow, declarations",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.expression",
                "keyword.other",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#f05a46"
            }
        },
        {
            "name": "Keyword — import, include, package",
            "scope": [
                "keyword.control.import",
                "keyword.control.include",
                "keyword.control.package",
                "keyword.control.namespace"
            ],
            "settings": {
                "foreground": "#f05a46"
            }
        },
        {
            "name": "Operator",
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment",
                "keyword.operator.comparison",
                "keyword.operator.arithmetic",
                "keyword.operator.logical"
            ],
            "settings": {
                "foreground": "#9a8878"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "string.quoted",
                "string.quoted.single",
                "string.quoted.double",
                "string.quoted.triple",
                "string.quoted.other",
                "string.unquoted"
            ],
            "settings": {
                "foreground": "#f1908c"
            }
        },
        {
            "name": "String — template & interpolation",
            "scope": [
                "string.template",
                "string.template variable",
                "string.interpolation",
                "string.interpolated"
            ],
            "settings": {
                "foreground": "#f1908c"
            }
        },
        {
            "name": "String — escape sequences",
            "scope": [
                "constant.character.escape",
                "constant.character.code"
            ],
            "settings": {
                "foreground": "#f1908c"
            }
        },
        {
            "name": "Number",
            "scope": [
                "constant.numeric",
                "constant.numeric.integer",
                "constant.numeric.float",
                "constant.numeric.hex",
                "constant.numeric.octal",
                "constant.numeric.binary"
            ],
            "settings": {
                "foreground": "#f05a46"
            }
        },
        {
            "name": "Constant — language & other",
            "scope": [
                "constant.language",
                "constant.other",
                "constant.other.color"
            ],
            "settings": {
                "foreground": "#f05a46"
            }
        },
        {
            "name": "Boolean & Null",
            "scope": [
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#f05a46"
            }
        },
        {
            "name": "Type — Class, Interface, Enum, Struct",
            "scope": [
                "entity.name.type",
                "entity.name.type.class",
                "entity.name.type.enum",
                "entity.name.type.interface",
                "entity.name.type.struct",
                "entity.name.type.type-alias",
                "entity.other.inherited-class"
            ],
            "settings": {
                "foreground": "#579572"
            }
        },
        {
            "name": "Function — Declaration & Call",
            "scope": [
                "entity.name.function",
                "entity.name.function.constructor",
                "meta.function-call",
                "support.function",
                "support.function.builtin",
                "support.function.console"
            ],
            "settings": {
                "foreground": "#83a78d"
            }
        },
        {
            "name": "Method — Declaration & Call",
            "scope": [
                "entity.name.function.member",
                "entity.name.method"
            ],
            "settings": {
                "foreground": "#83a78d"
            }
        },
        {
            "name": "Variable",
            "scope": [
                "variable",
                "variable.other.readwrite",
                "variable.other.property",
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#d4c4b7"
            }
        },
        {
            "name": "Parameter",
            "scope": [
                "variable.parameter",
                "variable.parameter.function"
            ],
            "settings": {
                "foreground": "#c1b2a3"
            }
        },
        {
            "name": "Property — Object & JSON keys",
            "scope": [
                "variable.other.object.property",
                "support.type.property-name",
                "meta.object-literal.key",
                "meta.structure.dictionary.key"
            ],
            "settings": {
                "foreground": "#9a8878"
            }
        },
        {
            "name": "Support — Built-in classes & types",
            "scope": [
                "support.class",
                "support.type",
                "support.constant",
                "support.variable"
            ],
            "settings": {
                "foreground": "#579572"
            }
        },
        {
            "name": "Punctuation — Brackets & Delimiters",
            "scope": [
                "punctuation",
                "punctuation.definition",
                "punctuation.section",
                "punctuation.terminator",
                "punctuation.separator",
                "punctuation.accessor",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#9a8878"
            }
        },
        {
            "name": "Markup — Heading",
            "scope": [
                "markup.heading",
                "entity.name.section",
                "markup.heading.setext"
            ],
            "settings": {
                "foreground": "#f05a46",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup — Bold & Italic",
            "scope": [
                "markup.bold",
                "markup.italic"
            ],
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup — List",
            "scope": [
                "markup.list",
                "markup.list.unnumbered",
                "markup.list.numbered"
            ],
            "settings": {
                "foreground": "#f05a46"
            }
        },
        {
            "name": "Markup — Link",
            "scope": [
                "markup.underline.link",
                "string.other.link"
            ],
            "settings": {
                "foreground": "#83a78d",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Markup — Code (inline & fenced)",
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code.block"
            ],
            "settings": {
                "foreground": "#f1908c"
            }
        },
        {
            "name": "Markup — Quote",
            "scope": [
                "markup.quote"
            ],
            "settings": {
                "foreground": "#9a8878",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup — Inserted/Deleted (diff)",
            "scope": [
                "markup.inserted",
                "markup.deleted"
            ],
            "settings": {
                "foreground": "#f1908c"
            }
        },
        {
            "name": "CSS — Class & ID selectors",
            "scope": [
                "entity.other.attribute-name.class",
                "entity.other.attribute-name.id"
            ],
            "settings": {
                "foreground": "#9a8878"
            }
        },
        {
            "name": "CSS — Property names & values",
            "scope": [
                "support.type.property-name.css",
                "support.type.property-name.media"
            ],
            "settings": {
                "foreground": "#9a8878"
            }
        },
        {
            "name": "Tag name (HTML/JSX/XML)",
            "scope": [
                "entity.name.tag"
            ],
            "settings": {
                "foreground": "#579572"
            }
        },
        {
            "name": "Tag attribute name",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#f1908c"
            }
        },
        {
            "name": "JSON Key",
            "scope": [
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#9a8878"
            }
        },
        {
            "name": "Diff — Header",
            "scope": [
                "meta.diff.header",
                "meta.diff.range",
                "meta.diff.index"
            ],
            "settings": {
                "foreground": "#c08eaf"
            }
        },
        {
            "name": "Invalid — Deprecated",
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#9a8878",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Invalid — Illegal",
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#f05a46"
            }
        }
    ],
