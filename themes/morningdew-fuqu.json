  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.double-slash",
        "comment.line.number-sign",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#8C8887",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment — documentation",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#9E9A98",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword — Control flow, declarations",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#A84242"
      }
    },
    {
      "name": "Keyword — import, include, package",
      "scope": [
        "keyword.control.import",
        "keyword.control.include",
        "keyword.control.package",
        "keyword.control.namespace"
      ],
      "settings": {
        "foreground": "#A84242"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.arithmetic",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#A84242"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.quoted.other",
        "string.unquoted"
      ],
      "settings": {
        "foreground": "#2A8B6F"
      }
    },
    {
      "name": "String — template & interpolation",
      "scope": [
        "string.template",
        "string.template variable",
        "string.interpolation",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#2A8B6F"
      }
    },
    {
      "name": "String — escape sequences",
      "scope": [
        "constant.character.escape",
        "constant.character.code"
      ],
      "settings": {
        "foreground": "#3A8A9A"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#9A6A4E"
      }
    },
    {
      "name": "Constant — language & other",
      "scope": [
        "constant.language",
        "constant.other",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#9A6A4E"
      }
    },
    {
      "name": "Boolean & Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#B87A3A"
      }
    },
    {
      "name": "Type — Class, Interface, Enum, Struct",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.enum",
        "entity.name.type.interface",
        "entity.name.type.struct",
        "entity.name.type.type-alias",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#2A6E8F"
      }
    },
    {
      "name": "Function — Declaration & Call",
      "scope": [
        "entity.name.function",
        "entity.name.function.constructor",
        "meta.function-call",
        "support.function",
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#7A5A8C"
      }
    },
    {
      "name": "Method — Declaration & Call",
      "scope": [
        "entity.name.function.member",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#7A5A8C"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.property",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5A5552"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#5A5552"
      }
    },
    {
      "name": "Property — Object & JSON keys",
      "scope": [
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "meta.structure.dictionary.key"
      ],
      "settings": {
        "foreground": "#5A5552"
      }
    },
    {
      "name": "Support — Built-in classes & types",
      "scope": [
        "support.class",
        "support.type",
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#2A6E8F"
      }
    },
    {
      "name": "Punctuation — Brackets & Delimiters",
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.section",
        "punctuation.terminator",
        "punctuation.separator",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#5A5552"
      }
    },
    {
      "name": "Markup — Heading",
      "scope": [
        "markup.heading",
        "entity.name.section",
        "markup.heading.setext"
      ],
      "settings": {
        "foreground": "#A84242",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup — Bold & Italic",
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup — List",
      "scope": [
        "markup.list",
        "markup.list.unnumbered",
        "markup.list.numbered"
      ],
      "settings": {
        "foreground": "#A84242"
      }
    },
    {
      "name": "Markup — Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#2A6E8F",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup — Code (inline & fenced)",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#2A8B6F",
        "background": "#F0ECE4"
      }
    },
    {
      "name": "Markup — Quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#8C8887",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup — Inserted/Deleted (diff)",
      "scope": [
        "markup.inserted",
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#3A8B5A"
      }
    },
    {
      "name": "CSS — Class & ID selectors",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#9A6A4E"
      }
    },
    {
      "name": "CSS — Property names & values",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.media"
      ],
      "settings": {
        "foreground": "#5A5552"
      }
    },
    {
      "name": "Tag name (HTML/JSX/XML)",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#A84242"
      }
    },
    {
      "name": "Tag attribute name",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2A8B6F"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#5A5552"
      }
    },
    {
      "name": "Diff — Header",
      "scope": [
        "meta.diff.header",
        "meta.diff.range",
        "meta.diff.index"
      ],
      "settings": {
        "foreground": "#7A5A8C"
      }
    },
    {
      "name": "Invalid — Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#B87A3A",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Invalid — Illegal",
      "scope": [
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#B84A4A",
        "background": "#FAEAEA"
      }
    }
  ],
