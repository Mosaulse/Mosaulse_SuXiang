    "tokenColors": [
        {
            "name": "Default foreground",
            "scope": ["source"],
            "settings": { "foreground": "#423729" }
        },
        {
            "name": "Comment",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#A29583" }
        },
        {
            "name": "Keyword",
            "scope": ["keyword", "storage.type", "storage.modifier"],
            "settings": { "foreground": "#C54131" }
        },
        {
            "name": "String",
            "scope": ["string", "punctuation.definition.string"],
            "settings": { "foreground": "#D96C4A" }
        },
        {
            "name": "Number & Constant",
            "scope": ["constant.numeric", "constant.language", "support.constant"],
            "settings": { "foreground": "#C54131" }
        },
        {
            "name": "Function name",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#1F987C" }
        },
        {
            "name": "Type & Class name",
            "scope": [
                "entity.name.type", "entity.name.class", "entity.name.tag",
                "support.type", "support.class"
            ],
            "settings": { "foreground": "#1F987C" }
        },
        {
            "name": "Variable & Parameter",
            "scope": ["variable", "variable.parameter", "variable.other"],
            "settings": { "foreground": "#423729" }
        },
        {
            "name": "Punctuation & Braces",
            "scope": ["punctuation", "meta.brace", "punctuation.definition"],
            "settings": { "foreground": "#7A6D5E" }
        },
        {
            "name": "HTML/XML Tag",
            "scope": ["entity.name.tag"],
            "settings": { "foreground": "#1F987C" }
        },
        {
            "name": "HTML/XML Attribute",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#C54131" }
        },
        {
            "name": "Object property & member",
            "scope": [
                "variable.other.property", "variable.other.object.property",
                "variable.other.member", "meta.object-literal.key",
                "support.variable.property"
            ],
            "settings": { "foreground": "#9A6A22" }
        },
        {
            "name": "Parameter",
            "scope": ["variable.parameter", "meta.function.parameters"],
            "settings": { "foreground": "#5F5548" }
        },
        {
            "name": "Module & namespace",
            "scope": ["entity.name.namespace", "entity.name.module", "support.module"],
            "settings": { "foreground": "#1F987C" }
        },
        {
            "name": "Decorator & annotation",
            "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.decorator"],
            "settings": { "foreground": "#C54131" }
        },
        {
            "name": "Regular expression",
            "scope": ["string.regexp", "constant.character.escape"],
            "settings": { "foreground": "#D96C4A" }
        },
        {
            "name": "JSON key",
            "scope": [
                "support.type.property-name.json",
                "meta.structure.dictionary.json string.quoted.double.json"
            ],
            "settings": { "foreground": "#1F987C" }
        },
        {
            "name": "CSS selector & property",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css",
                "support.type.property-name.css"
            ],
            "settings": { "foreground": "#1F987C" }
        },
        {
            "name": "Markdown heading",
            "scope": ["markup.heading", "punctuation.definition.heading"],
            "settings": { "foreground": "#C54131" }
        },
        {
            "name": "Markdown link & inline code",
            "scope": ["markup.inline.raw", "markup.underline.link", "string.other.link"],
            "settings": { "foreground": "#1F987C" }
        },
        {
            "name": "Invalid",
            "scope": "invalid",
            "settings": { "foreground": "#C54131" }
        }
    ],
    "semanticTokenColors": {
        "namespace": "#1F987C",
        "type": { "foreground": "#1F987C" },
        "class": { "foreground": "#1F987C" },
        "interface": { "foreground": "#1F987C" },
        "enum": "#1F987C",
        "typeParameter": "#1F987C",
        "function": "#1F987C",
        "method": "#1F987C",
        "macro": "#C54131",
        "variable": "#423729",
        "parameter": "#5F5548",
        "property": "#9A6A22",
        "enumMember": "#C54131",
        "event": "#C54131",
        "decorator": "#C54131",
        "label": "#7A6D5E",
        "keyword": { "foreground": "#C54131" },
        "string": "#D96C4A",
        "number": "#C54131",
        "regexp": "#D96C4A",
        "operator": "#7A6D5E",
        "comment": { "foreground": "#A29583" },
        "*.deprecated": { "foreground": "#A29583" }
    }
}
