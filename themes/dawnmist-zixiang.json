    "tokenColors": [
        {
            "name": "Default foreground",
            "scope": ["source"],
            "settings": { "foreground": "#3D2E45" }
        },
        {
            "name": "Comment",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#998DA3" }
        },
        {
            "name": "Keyword",
            "scope": ["keyword", "storage.type", "storage.modifier"],
            "settings": { "foreground": "#B54160" }
        },
        {
            "name": "String",
            "scope": ["string", "punctuation.definition.string"],
            "settings": { "foreground": "#D6738A" }
        },
        {
            "name": "Number & Constant",
            "scope": ["constant.numeric", "constant.language", "support.constant"],
            "settings": { "foreground": "#6E5F77" }
        },
        {
            "name": "Function name",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#7A5A92" }
        },
        {
            "name": "Type & Class name",
            "scope": [
                "entity.name.type", "entity.name.class", "entity.name.tag",
                "support.type", "support.class"
            ],
            "settings": { "foreground": "#9D7BB8" }
        },
        {
            "name": "Variable & Parameter",
            "scope": ["variable", "variable.parameter", "variable.other"],
            "settings": { "foreground": "#3D2E45" }
        },
        {
            "name": "Punctuation & Braces",
            "scope": ["punctuation", "meta.brace", "punctuation.definition"],
            "settings": { "foreground": "#6E5F77" }
        },
        {
            "name": "HTML/XML Attribute",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#B54160" }
        },
        {
            "name": "Object property & member",
            "scope": [
                "variable.other.property", "variable.other.object.property",
                "variable.other.member", "meta.object-literal.key",
                "support.variable.property"
            ],
            "settings": { "foreground": "#A86E22" }
        },
        {
            "name": "Module & namespace",
            "scope": ["entity.name.namespace", "entity.name.module", "support.module"],
            "settings": { "foreground": "#7A5A92" }
        },
        {
            "name": "Decorator & annotation",
            "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.decorator"],
            "settings": { "foreground": "#A86E22" }
        },
        {
            "name": "Regular expression",
            "scope": ["string.regexp", "constant.character.escape"],
            "settings": { "foreground": "#A86E22" }
        },
        {
            "name": "JSON key",
            "scope": [
                "support.type.property-name.json",
                "meta.structure.dictionary.json string.quoted.double.json"
            ],
            "settings": { "foreground": "#7A5A92" }
        },
        {
            "name": "CSS selector & property",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css",
                "support.type.property-name.css"
            ],
            "settings": { "foreground": "#9D7BB8" }
        },
        {
            "name": "Markdown heading",
            "scope": ["markup.heading", "punctuation.definition.heading"],
            "settings": { "foreground": "#B54160" }
        },
        {
            "name": "Markdown link & inline code",
            "scope": ["markup.inline.raw", "markup.underline.link", "string.other.link"],
            "settings": { "foreground": "#7A5A92" }
        },
        {
            "name": "Invalid",
            "scope": "invalid",
            "settings": { "foreground": "#B54160" }
        }
    ],
    "semanticTokenColors": {
        "namespace": "#7A5A92",
        "type": { "foreground": "#9D7BB8" },
        "class": { "foreground": "#9D7BB8" },
        "interface": { "foreground": "#9D7BB8" },
        "enum": "#7A5A92",
        "typeParameter": "#9D7BB8",
        "function": "#7A5A92",
        "method": "#7A5A92",
        "macro": "#A86E22",
        "variable": "#3D2E45",
        "parameter": "#6E5F77",
        "property": "#A86E22",
        "enumMember": "#B54160",
        "event": "#D6738A",
        "decorator": "#A86E22",
        "label": "#6E5F77",
        "keyword": { "foreground": "#B54160" },
        "string": "#D6738A",
        "number": "#6E5F77",
        "regexp": "#A86E22",
        "operator": "#6E5F77",
        "comment": { "foreground": "#998DA3" },
        "*.deprecated": { "foreground": "#998DA3" },
        "boolean": "#A86E22",
        "builtin": "#9D7BB8",
        "self": { "foreground": "#6E5F77", "fontStyle": "italic" },
        "*.readonly": { "foreground": "#9D7BB8", "fontStyle": "bold" }
    }
}
